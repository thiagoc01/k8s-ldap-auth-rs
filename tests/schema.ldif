dn: cn=ad-schema,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: ad-schema
olcAttributeTypes: ( 1.2.840.113556.1.4.221 NAME 'sAMAccountName' DESC 'Active Directory SAM-Account-Name' EQUALITY caseIgnoreMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 SINGLE-VALUE )
olcObjectClasses: ( 1.2.840.113556.1.5.6 NAME 'securityPrincipal' SUP top AUXILIARY MUST ( sAMAccountName ) )

dn: cn=k8stoken,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: k8stoken
olcAttributeTypes: ( 1.3.6.1.4.1.99998.1.1
  NAME 'k8sToken'
  DESC 'Hashed token in SHA256 or SHA512 format for Kubernetes webhook authentication'
  EQUALITY caseExactMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
  SINGLE-VALUE )
olcObjectClasses: ( 1.3.6.1.4.1.99998.2.1
  NAME 'k8sAuthToken'
  DESC 'Auxiliary class for Kubernetes webhook authentication token'
  SUP top
  AUXILIARY
  MAY ( k8sToken ) )

dn: cn=k8stoken2,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: k8stoken2
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1
  NAME 'k8sToken2'
  DESC 'Hashed token in SHA256 or SHA512 format for Kubernetes webhook authentication'
  EQUALITY caseExactMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
  SINGLE-VALUE )
olcObjectClasses: ( 1.3.6.1.4.1.99999.2.1
  NAME 'k8sAuthToken2'
  DESC 'Auxiliary class for Kubernetes webhook authentication token'
  SUP top
  AUXILIARY
  MAY ( k8sToken2 ) )
