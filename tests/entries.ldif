objectClass: posixAccount
objectClass: shadowAccount
uid: johndoe
cn: John Doe
sn: Doe
mail: john@example.test
userPassword: johndoepass
uidNumber: 10001
gidNumber: 10001
homeDirectory: /home/johndoe
