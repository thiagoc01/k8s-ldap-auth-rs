memberOf: cn=infra,ou=groups,dc=example,dc=test

# --- valid user, single group ---
dn: uid=alicecooper,ou=users,dc=example,dc=test
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount
objectClass: securityPrincipal
sAMAccountName: alicecooper
uid: alicecooper
cn: Alice Cooper
sn: Cooper
mail: alice@example.test
userPassword: alicecooperpass
uidNumber: 10002
gidNumber: 10002
homeDirectory: /home/alicecooper

# --- duplicate uid in another subtree: tests ambiguous search results ---
dn: uid=johndoe,ou=sysaccounts,dc=example,dc=test
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount
uid: johndoe
cn: John
sn: Doe
uidNumber: 10003
gidNumber: 10003
